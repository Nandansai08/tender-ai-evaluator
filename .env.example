# Tender AI Evaluator — Environment Configuration
# Copy this file to .env and fill in your settings

# ─── AI Configuration ─────────────────────────────────────────────────────────
# OpenAI API key. Leave empty to use the built-in mock AI (no API key required).
OPENAI_API_KEY=

# OpenAI model to use for structured extraction
OPENAI_MODEL=gpt-4o

# Set to "true" to force mock AI even when OPENAI_API_KEY is set (useful for testing)
USE_MOCK_AI=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./tender_evaluator.db

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
REPORTS_DIR=reports_output
MAX_UPLOAD_SIZE_MB=50

# ─── Evaluation Thresholds ────────────────────────────────────────────────────
# Confidence >= this → ELIGIBLE
CONFIDENCE_THRESHOLD_ELIGIBLE=0.75

# Confidence >= this → NEEDS_REVIEW (otherwise NOT_ELIGIBLE for mandatory criteria)
CONFIDENCE_THRESHOLD_REVIEW=0.40

# ─── Debug ────────────────────────────────────────────────────────────────────
DEBUG=false
